# ========== Elasticsearch ==========
ES_HOSTS=http://elasticsearch:9200
ES_RAW_INDEX=news_raw
ES_PROCESSED_INDEX=news_processed

# ========== Kafka ==========
KAFKA_BOOTSTRAP_SERVERS=kafka-v4:29092
KAFKA_RAW_TOPIC=raw_news
KAFKA_PROCESSED_TOPIC=processed_data

# ========== Embedding API ==========
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=sk-your-api-key-here
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIM=1536
# EMBEDDING_API_URL=https://api.jina.ai/v1/embeddings
# EMBEDDING_API_KEY=jina_your_key_here
# EMBEDDING_MODEL=jina-embeddings-v3
# EMBEDDING_DIM=1024

# ========== Crawler ==========
CRAWLER_POLL_INTERVAL=60
USER_AGENT=Mozilla/5.0 (compatible; NewsCrawler/1.0; +https://example.com/bot)
REQUEST_TIMEOUT=8
